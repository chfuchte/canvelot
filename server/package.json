{
    "name": "canvelot-server",
    "private": true,
    "version": "0.3.1",
    "type": "module",
    "scripts": {
        "start": "node dist/index.js",
        "start-env": "node --env-file-if-exists=.env.local dist/index.js",
        "build": "esbuild src/index.ts --bundle --platform=node --format=esm --target=node18 --outdir=dist --packages=external",
        "build-tsc": "tsc",
        "typecheck": "tsc --noEmit",
        "format": "prettier --write ."
    },
    "dependencies": {
        "better-auth": "^1.6.18",
        "cors": "^2.8.6",
        "express": "^5.2.1",
        "mongodb": "^7.3.0",
        "raw-body": "^3.0.2",
        "zlib": "^1.0.5",
        "zod": "^4.4.3"
    },
    "devDependencies": {
        "@excalidraw/excalidraw": "^0.18.1",
        "@types/cors": "^2.8.19",
        "@types/express": "^5.0.6",
        "@types/node": "^25.9.3",
        "esbuild": "^0.28.1",
        "prettier": "^3.8.4",
        "typescript": "^6.0.3"
    }
}
